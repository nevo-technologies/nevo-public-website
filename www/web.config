<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<appSettings>
		<add key="MailTo" value="feedback@nevo.com" />
		<add key="MailBcc" value="pjaffe@nevo.com" />
	</appSettings>
	<system.webServer>
		<directoryBrowse enabled="false" />
		<staticContent>
			<clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00" />
		</staticContent>
		<defaultDocument>
			<files>
				<clear />
				<add value="index.html" />
			</files>
		</defaultDocument>
		<modules runAllManagedModulesForAllRequests="true" />
        <httpRedirect enabled="true" exactDestination="true" httpResponseStatus="Found">
             <add wildcard="/our-story/*" destination="http://nevo.com/" />
             <add wildcard="/our-people/*" destination="http://nevo.com/" />
             <add wildcard="/our-home/*" destination="http://nevo.com/" />
             <add wildcard="/NewWebsite/*" destination="http://nevo.com/" />
        </httpRedirect>
        <httpErrors>
            <remove statusCode="404" subStatusCode="-1" />
            <error statusCode="404" prefixLanguageFilePath="" path="http://nevo.com" responseMode="Redirect" />
        </httpErrors>
	</system.webServer>
	<system.web>
		<compilation debug="true" />
		<customErrors mode="On" defaultRedirect="http://nevo.com/">
      		<error statusCode="404" redirect="http://nevo.com/" />
    	</customErrors>
    </system.web>
	<location path="our-home/home.htm">
        <system.webServer>
          <httpRedirect enabled="true" destination="http://nevo.com/" httpResponseStatus="Permanent" />
        </system.webServer>
    </location>
	<location path="our-knowledge/whitepapers.asp">
        <system.webServer>
          <httpRedirect enabled="true" destination="http://nevo.com/" httpResponseStatus="Permanent" />
        </system.webServer>
    </location>
</configuration>