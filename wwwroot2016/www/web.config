<?xml version="1.0"?>
<configuration>
	<appSettings>
		<add key="contactEmailTo" value="okagan@nevo.com"/>
		<add key="contactEmailBcc" value="okagan@nevo.com"/>
		<add key="contactEmailSubject" value="NevoWebsite Contact Message"/>
	</appSettings>
	<system.webServer>
		<directoryBrowse enabled="true"/>
		<staticContent>
			<clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00"/>
		</staticContent>
		<defaultDocument>
			<files>
				<clear/>
				<add value="index.html"/>
			</files>
		</defaultDocument>
	</system.webServer>
	<system.web>
		<compilation debug="true" />
		<customErrors mode="Off"/>
	</system.web>
</configuration>
